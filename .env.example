NODE_ENV=development
PORT=3000
APP_PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=info
HTTP_ACCESS_LOG_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_WEBHOOK_MAX_REQUESTS=600
RATE_LIMIT_ALERT_BLOCKED_REQUESTS_1H_HIGH=100
DATABASE_URL=mysql://bot:botpass@mariadb:3306/kumpeapps_bot
GITHUB_API_TOKEN=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_API_POST_MAX_RETRIES=2
GITHUB_API_POST_RETRY_BASE_DELAY_MS=300
GITHUB_API_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
GITHUB_API_CIRCUIT_BREAKER_COOLDOWN_MS=60000
GITHUB_API_ALERT_FINAL_FAILURES_1H_HIGH=10
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=replace_me
ADMIN_API_TOKEN=replace_me
ADMIN_GITHUB_USERNAME=
ADMIN_SESSION_SECRET=
ADMIN_API_OWNER_TOKEN=
ADMIN_API_OPERATOR_TOKEN=
ADMIN_API_AUDITOR_TOKEN=
ADMIN_RBAC_DB_BINDINGS_ENABLED=true
ADMIN_RBAC_BOOTSTRAP_FROM_ENV=true
ADMIN_API_ALERT_AUTH_FAILURES_1H_HIGH=20
WEBHOOK_SYNC_RETRY_ATTEMPTS=2
WEBHOOK_SYNC_RETRY_BASE_DELAY_MS=300
WEBHOOK_DELIVERY_IN_PROGRESS_LEASE_MS=300000
WEBHOOK_DELIVERY_RETENTION_DAYS=30
WEBHOOK_ALERT_FAILED_24H_HIGH=20
WEBHOOK_ALERT_IN_PROGRESS_HIGH=10
WEBHOOK_ALERT_STALE_RECLAIMS_24H_HIGH=5
WEBHOOK_ALERT_DUPLICATE_SUPPRESSIONS_24H_HIGH=100
WEBHOOK_ALERT_INVALID_SIGNATURES_1H_HIGH=20
DEPLOY_EXECUTION_DRY_RUN_ONLY=true
DEPLOY_QUEUE_CONCURRENCY=1
DEPLOY_QUEUE_POLL_INTERVAL_MS=1000
DEPLOY_QUEUE_RUNNING_LEASE_MS=900000
DEPLOY_QUEUE_JOB_TIMEOUT_MS=1800000
DEPLOY_QUEUE_JOB_RETENTION_DAYS=30
DEPLOY_QUEUE_ALERT_QUEUE_DEPTH_HIGH=20
DEPLOY_QUEUE_ALERT_SUCCESS_RATE_MIN_PERCENT=80
DEPLOY_QUEUE_ALERT_TIMEOUT_FAILURES_24H_HIGH=5
DEPLOY_QUEUE_ALERT_LEASE_RECLAIMS_24H_HIGH=5
DEPLOY_QUEUE_ALERT_USER_REQUEUES_24H_HIGH=10
DEPLOY_QUEUE_ALERT_MAX_SNOOZE_MINUTES=240
DEPLOY_QUEUE_ALERT_SNOOZE_RETENTION_DAYS=90
DEPLOY_COMPENSATION_VM_COMPOSE_DOWN_ENABLED=true
DEPLOY_COMPENSATION_ALERT_FAILURES_24H_HIGH=3
VM_SSH_USER=root
VM_SSH_KEY_PATH=/root/.ssh/id_rsa
VM_SSH_PORT=22
VM_DEPLOY_BASE_DIR=/opt/kumpeapps
SSH_CONNECT_TIMEOUT_SECONDS=15
SSH_COMMAND_RETRIES=2
SSH_ALERT_FINAL_FAILURES_1H_HIGH=10
SSH_ALERT_TIMEOUT_FAILURES_1H_HIGH=3
SSH_STRICT_HOST_KEY_CHECKING=accept-new
SSH_KNOWN_HOSTS_PATH=/root/.ssh/known_hosts
CADDY_SSH_USER=root
CADDY_SSH_KEY_PATH=/root/.ssh/id_rsa
CADDY_SSH_PORT=22
CADDY_CONFIG_DIR=/etc/caddy/sites-enabled
CADDY_VALIDATE_COMMAND=
CADDY_RELOAD_COMMAND=sudo systemctl reload caddy
VIRTUALIZOR_MODE=dryrun
VIRTUALIZOR_API_URL=
VIRTUALIZOR_API_KEY=
VIRTUALIZOR_API_PASS=
VIRTUALIZOR_API_INSECURE=false
VIRTUALIZOR_API_TIMEOUT_MS=15000
VIRTUALIZOR_CREATE_ENABLED=true
VIRTUALIZOR_DEFAULT_PLAN=
# Environment-specific plan IDs (override VIRTUALIZOR_DEFAULT_PLAN per environment)
VIRTUALIZOR_DEV_PLAN=
VIRTUALIZOR_STAGE_PLAN=
VIRTUALIZOR_PROD_PLAN=
VIRTUALIZOR_DEFAULT_REGION=
VIRTUALIZOR_DEFAULT_OS=
VIRTUALIZOR_DEFAULT_USER=
# VM credentials (required for VM creation)
VIRTUALIZOR_VM_USER_EMAIL=
VIRTUALIZOR_VM_USER_PASS=
VIRTUALIZOR_VM_ROOT_PASS=
# Environment-specific server IDs
VIRTUALIZOR_DEV_SERVER=
VIRTUALIZOR_STAGE_SERVER=
VIRTUALIZOR_PROD_SERVER=
VIRTUALIZOR_ALERT_API_FAILURES_1H_HIGH=10
VIRTUALIZOR_ALERT_VM_READY_TIMEOUTS_1H_HIGH=3
VIRTUALIZOR_VM_READY_POLL_INTERVAL_MS=5000
VIRTUALIZOR_VM_READY_TIMEOUT_MS=300000
GITHUB_DEPLOYMENTS_ENABLED=false
# Managed Nebula VPN Provisioning
# Automatically creates VPN clients for dev, stage, and prod environments when repos are registered
MANAGED_NEBULA_ENABLED=false
MANAGED_NEBULA_API_URL=
MANAGED_NEBULA_API_KEY=
MANAGED_NEBULA_API_TIMEOUT_MS=30000
MANAGED_NEBULA_IP_POOL_ID=1
MANAGED_NEBULA_IP_GROUP_POOL_ID=
# Environment-specific group IDs (comma-separated, e.g., "1,2,3")
MANAGED_NEBULA_DEV_GROUP_IDS=
MANAGED_NEBULA_STAGE_GROUP_IDS=
MANAGED_NEBULA_PROD_GROUP_IDS=
# Environment-specific firewall ruleset IDs (comma-separated, e.g., "1,2")
MANAGED_NEBULA_DEV_FIREWALL_RULE_IDS=
MANAGED_NEBULA_STAGE_FIREWALL_RULE_IDS=
MANAGED_NEBULA_PROD_FIREWALL_RULE_IDS=
SECRET_ENCRYPTION_KEY=replace-with-long-random-string
SECRET_ENCRYPTION_PREVIOUS_KEYS=
SECRET_ENCRYPTION_ALERT_DECRYPT_FAILURES_1H_HIGH=3
AUTO_DEPLOY_ENABLED=false
AUTO_DEPLOY_DRY_RUN=true
AUTO_DEPLOY_CADDY_HOST=localhost
# Repository Token Provisioning (auto-generated per-repo API tokens)
# Tokens are encrypted with TweetNaCl sealed box and pushed to repos as secrets
REPOSITORY_TOKEN_PROVISIONING_ENABLED=true
REPOSITORY_TOKEN_PROVISIONING_INTERVAL_MS=3600000
# Webhook Retry System (not yet implemented)
WEBHOOK_RETRY_ENABLED=true
WEBHOOK_RETRY_MAX_ATTEMPTS=3
WEBHOOK_RETRY_INTERVAL_MS=300000
